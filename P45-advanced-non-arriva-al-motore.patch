+/// dove il nodo li gestisce da sé sulla porta catch.
+pub fn goes_to_handler(config: &serde_json::Value, spec: &serde_json::Value) -> bool {
+    let mode = advanced(config, spec)
         .and_then(|a| a.get("onError"))
         .and_then(|v| v.as_str())
         .unwrap_or("handler");
