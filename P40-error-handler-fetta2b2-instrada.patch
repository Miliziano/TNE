+        if eh_subpipe.contains(&node_id_str) {
+            eh_handles.push((node_id_str, handle));
+        } else {
+            handles.push((node_id_str, handle));
+        }
     }
 
     // ── 4. Attendi completamento ──────────────────────────────────
