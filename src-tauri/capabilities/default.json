{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "FlowPilot Studio — permessi desktop",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-remove",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-stat",
    "fs:allow-rename",
    "fs:scope-home-recursive",
    "fs:scope-document-recursive",
    "fs:scope-download-recursive",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "shell:default",
    "shell:allow-spawn",
    "shell:allow-execute",
    "shell:allow-kill",
    "log:default",
    "log:allow-log",
    "fs:allow-watch"
   
  ]
}