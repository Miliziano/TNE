-            });
+    // Drena gli errori raccolti (una volta): li registra nel pannello log E
+    // li instrada alla sotto-pipeline collegata a error_out.
+    let drained = if !lane_errors.is_empty().await {
+        lane_errors.drain().await
+    } else {
+        Vec::new()
+    };
+    for row in &drained {
